# ── Required ───────────────────────────────────────────────────────────────
BOT_TOKEN=               # Telegram bot token from @BotFather
DOOR_API_URL=            # Door status API, returns { status, timestamp }

# ── Optional ───────────────────────────────────────────────────────────────
WEB_SERVER_PORT=3000     # Express dashboard port
ADMIN_CHAT_ID=           # Telegram chat id that receives crawler health alerts
DEVELOPMENT=             # "1" enables DEBUG logs and skips persisting logs to the DB
                         # (nodemon sets this automatically for `npm run dev`)

# Logical-day cutoff hour (0–23). A "day" runs from this hour to this hour, so a
# Friday opening that closes after midnight still counts as Friday. Used by the
# opening streak and the First-Open→Last-Close band (Fig 3).
DAY_START_HOUR=3

# Timezone used for "current shift" lookups (defaults to Europe/Berlin).
TIMEZONE=Europe/Berlin

# Scheduled crawler cadence (milliseconds).
SHIFT_PLAN_SCAN_MS=86400000     # shift plan: default once a day
SEMESTER_SCAN_MS=604800000      # semester dates: default once a week

# Scrape sources (override only if the upstream URLs move).
SHIFT_PLAN_URL=https://wiki.mathe-cafe.de/en/schichtplan
SEMESTER_DATES_URL=https://www.tu.berlin/studieren/bewerben-und-einschreiben/fristen-termine
